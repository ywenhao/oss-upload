{
  "name": "@bmjs/oss-upload",
  "type": "module",
  "version": "0.0.8",
  "description": "阿里云oss、腾讯云cos、华为云obs、七牛云 对象存储上传工具",
  "author": "ywenhao",
  "license": "MIT",
  "keywords": [
    "oss",
    "obs",
    "qiniu",
    "cos",
    "ali-oss",
    "oss upload",
    "对象存储"
  ],
  "sideEffects": false,
  "exports": {
    "./*": {
      "import": {
        "types": "./dist/*.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "bin": {
    "oss-upload": "./dist/upload/cli.mjs"
  },
  "files": [
    "*.d.ts",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "ansis": "^4.2.0",
    "consola": "^3.4.2",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "esdk-obs-nodejs": "^3.25.6",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "qiniu": "^7.15.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@types/ali-oss": "^6.23.3",
    "@types/node": "^25.2.3",
    "eslint": "^9.39.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "unconfig": "^7.4.2"
  },
  "overrides": {
    "semver": "^7.7.4"
  },
  "pnpm": {
    "overrides": {
      "semver": "^7.7.4"
    }
  }
}
